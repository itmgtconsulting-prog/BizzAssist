# ══════════════════════════════════════════════════════════════════════════════
# BizzAssist — Environment Variables Template
#
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local
#
# NEVER commit .env.local to git — it contains secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ACCESS_TOKEN=                    # Management API token (for schema operations)

# ─── Sentry (error monitoring) ─────────────────────────────────────────────────
SENTRY_ORG=bizzassist
SENTRY_PROJECT=bizzassist
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── AI (Claude API) ──────────────────────────────────────────────────────────
BIZZASSIST_CLAUDE_KEY=sk-ant-api03-...

# ─── CVR ElasticSearch (system-til-system) ─────────────────────────────────────
CVR_ES_USER=                              # Erhvervsstyrelsen credentials
CVR_ES_PASS=

# ─── Datafordeler ──────────────────────────────────────────────────────────────
# API key (free services: BBR, MAT, DAR)
DATAFORDELER_API_KEY=
# WMS credentials (matrikelkort layers)
DATAFORDELER_WMS_USERNAME=
DATAFORDELER_WMS_PASSWORD=
# OAuth Shared Secret (confidential services: VUR, EJF)
DATAFORDELER_OAUTH_CLIENT_ID=
DATAFORDELER_OAUTH_CLIENT_SECRET=
# mTLS Certificate (EJF property portfolio — optional)
DATAFORDELER_CERT_CLIENT_ID=
DATAFORDELER_CERT_PATH=                   # Path to .p12 file, OR use base64:
# DATAFORDELER_CERT_PFX_BASE64=           # Base64-encoded .p12 (for Vercel)
DATAFORDELER_CERT_PASSWORD=
# Hetzner proxy (required on Vercel — optional for local dev)
# DF_PROXY_URL=
# DF_PROXY_SECRET=

# ─── Tinglysning (mTLS) ───────────────────────────────────────────────────────
TINGLYSNING_CERT_PATH=                    # Path to .p12 file, OR use base64:
# TINGLYSNING_CERT_B64=                   # Base64-encoded .p12 (for Vercel)
TINGLYSNING_CERT_PASSWORD=
TINGLYSNING_BASE_URL=https://test.tinglysning.dk

# ─── Energimærkning (EMO) ──────────────────────────────────────────────────────
EMO_USERNAME=
EMO_PASSWORD=

# ─── Mapbox ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ─── Stripe (payments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Twilio (SMS notifications — optional) ────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# ALERT_PHONE_NUMBER=

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── GitHub (Release Agent) ───────────────────────────────────────────────────
# GITHUB_REPO=owner/repo
# GITHUB_TOKEN=ghp_...

# ─── Vercel (Service Manager) ─────────────────────────────────────────────────
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

# ─── Cron Security ────────────────────────────────────────────────────────────
CRON_SECRET=                              # Bearer token for cron routes

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Search APIs (optional) ───────────────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=

# ─── JIRA (optional — for bug reports + backlog) ──────────────────────────────
# JIRA_HOST=bizzassist.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=BIZZ

# ─── Bootstrap (one-time admin setup) ─────────────────────────────────────────
# BOOTSTRAP_SECRET=
