{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000"
    },
    {
      "name": "Vitest: run all tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm test"
    },
    {
      "name": "Vitest: watch mode",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test:watch"
    },
    {
      "name": "Playwright: run E2E tests",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run test:e2e"
    }
  ]
}
