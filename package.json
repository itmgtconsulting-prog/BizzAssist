{
  "name": "bizzassist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "backup:env": "node -e \"const fs=require('fs'),p=require('path');const s=p.join(__dirname,'.env.local');if(!fs.existsSync(s)){process.exit(0)}const d=p.join(__dirname,'.env-backups');fs.mkdirSync(d,{recursive:true});const t=new Date().toISOString().replace(/[:.]/g,'-').slice(0,19);fs.copyFileSync(s,p.join(d,'.env.local.'+t));console.log('Backup: .env-backups/.env.local.'+t)\"",
    "predev": "npm run backup:env 2>&1 || true && node -e \"try{require('fs').rmSync('.next/dev',{recursive:true,force:true})}catch{}\"",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test __tests__/e2e/smoke.spec.ts",
    "test:rls": "RLS_TEST=true vitest run --config vitest.rls.config.ts",
    "test:rls:script": "node scripts/test-rls.mjs",
    "test:domain:integration": "INTEGRATION=1 vitest run __tests__/domain/isolation.integration.test.ts",
    "test:all": "npm run test && npm run test:e2e",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:migrate:up": "node scripts/run-migrations.mjs",
    "db:reset": "node scripts/migrate.js --reset",
    "db:seed": "node scripts/seed.js",
    "docker:dev": "docker compose up",
    "docker:build": "docker compose build",
    "docker:down": "docker compose down",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.54",
    "@types/pdfkit": "^0.17.5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.10.2",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "mapbox-gl": "^3.20.0",
    "next": "16.2.3",
    "next-pwa": "^5.6.0",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "stripe": "^21.0.1",
    "twilio": "^5.13.1",
    "xml-crypto": "^6.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.58.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
