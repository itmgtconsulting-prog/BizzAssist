{
  "_webhooks": {
    "_doc": "Vercel deploy webhook — configure in Project Settings → Git → Webhooks",
    "url": "https://test.bizzassist.dk/api/webhooks/vercel-deploy?secret=<VERCEL_DEPLOY_WEBHOOK_SECRET>",
    "events": ["deployment.created", "deployment.succeeded", "deployment.error"],
    "secret_env_var": "VERCEL_DEPLOY_WEBHOOK_SECRET"
  },
  "crons": [
    {
      "path": "/api/cron/poll-properties",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/deep-scan",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/warm-cache",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/service-scan",
      "schedule": "0 * * * *"
    }
  ]
}
